# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aivibe_user:YOUR_PASSWORD@127.0.0.1:5432/aivibe_db

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-random-string-at-least-32-chars

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGINS=http://localhost:8080,http://localhost:3001

# ── Firecrawl (site scraping) ─────────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-your-key-here

# ── AI / OpenAI-compatible (query-content) ────────────────────────────────────
AI_API_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4o-mini

# ── Lemonade (optional chat provider) ─────────────────────────────────────────
LEMONADE_API_KEY=your-lemonade-key
LEMONADE_ID=your-lemonade-id

# ── Refresh (cron job secret) ─────────────────────────────────────────────────
REFRESH_SECRET=replace-with-another-random-string

{
    "name": "ai-vibe-card-api",
    "version": "1.0.0",
    "type": "module",
    "description": "Express API backend for AI Vibe Card — runs on Scala Hosting VPS",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "migrate:up": "node-pg-migrate -m migrations -j ts up",
        "migrate:down": "node-pg-migrate -m migrations -j ts down",
        "migrate:create": "node-pg-migrate -m migrations -j ts create",
        "migrate:status": "node-pg-migrate -m migrations -j ts status",
        "migrate:up:prod": "node-pg-migrate -m dist/migrations -j js up"
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^8.3.2",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.1.1",
        "node-pg-migrate": "^8.0.4",
        "nodemailer": "^8.0.5",
        "pg": "^8.11.3",
        "pino": "^9.5.0",
        "pino-http": "^10.3.0",
        "undici": "^8.1.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/multer": "^2.1.0",
        "@types/nodemailer": "^8.0.0",
        "@types/pg": "^8.10.9",
        "pino-pretty": "^11.2.2",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3"
    }
}

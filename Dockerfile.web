# syntax=docker/dockerfile:1.7

# ─── Stage 1: build the React/Vite frontend ──────────────────────────────────
FROM node:20-alpine AS build
WORKDIR /build

COPY package.json package-lock.json ./
RUN npm ci

COPY . .
RUN npm run build

# ─── Stage 2: nginx serving the built static + proxying /api ─────────────────
FROM nginx:1.27-alpine AS runtime

# Copy built static. nginx:alpine runs as root by default but only opens a
# privileged port if you ask it to; we only listen on 8080 so we can run
# unprivileged. The nginx-unprivileged image would also work but adds a dep.
COPY --from=build /build/dist /usr/share/nginx/html
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf

# Drop root: write pid + cache to a user-writable path.
RUN sed -i 's@^pid .*@pid /tmp/nginx.pid;@' /etc/nginx/nginx.conf \
 && sed -i 's@^user .*@@' /etc/nginx/nginx.conf \
 && chown -R nginx:nginx /usr/share/nginx/html /var/cache/nginx /var/log/nginx /etc/nginx/conf.d

USER nginx

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD wget -qO- http://127.0.0.1:8080/healthz >/dev/null 2>&1 || exit 1

CMD ["nginx", "-g", "daemon off;"]

# Production .env for docker-compose. Copy to .env beside docker-compose.yml,
# fill in values, then `chmod 600 .env`.
#
# Generate JWT_SECRET:    openssl rand -hex 32
# Generate ENCRYPTION_KEY: openssl rand -hex 32
# Generate POSTGRES_PASSWORD: openssl rand -base64 24

# ── Supabase (front end) ─────────────────────────────────────────────────────
# These are read at *build time* by Vite and inlined into the static bundle
# uploaded to the Scala VPS. They are public values — RLS policies in Supabase
# are the security boundary, not these keys.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-supabase-anon-jwt

# ── Database ─────────────────────────────────────────────────────────────────
# Only used by the legacy self-hosted Express API while the Supabase migration
# is in progress. Will be removed once all routes are ported.
POSTGRES_PASSWORD=replace-with-strong-password

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-32-plus-char-random-string
ENCRYPTION_KEY=replace-with-64-char-hex-string

# ── Public origin(s) — comma-separated, no trailing slash ────────────────────
CORS_ORIGINS=https://ai.60wattsofclarity.com

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── External integrations (optional — leave blank to disable that feature) ──
FIRECRAWL_API_KEY=
AI_API_URL=
AI_API_KEY=
AI_MODEL=
LEMONADE_API_KEY=
LEMONADE_CONTENT_ID=
LEMONADE_SECURITY_ID=
# Default visitor-chat agent for /card/<slug> (platform-billed). Card owners
# can opt into BYOK via api_connections instead; leaving this blank disables
# chat for anyone without their own key.
LEMONADE_CHAT_ID=
REFRESH_SECRET=

# ── Email (optional — leave blank to disable email notifications) ────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
